{
  "name": "music-video-studio",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web",
    "packages/shared"
  ],
  "scripts": {
    "dev": "concurrently -k -p \"[{name}]\" -n \"api,web\" -c \"yellow,cyan\" \"PORT=3001 npm run dev:api\" \"PORT=3000 npm run dev:web\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web && npm run build --workspace=apps/api",
    "start": "npm run start --workspace=apps/api",
    "lint": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "happy-dom": "^20.9.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.5"
  }
}