# Copy this file to .env and fill in values

# Required for AI generation
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# Modal endpoints (deploy modal/ scripts first)
MODAL_AUDIO_URL=
MODAL_LTX_URL=

# Public URL of this service (used for webhook callbacks to Modal)
PUBLIC_BASE_URL=http://localhost:3001

# CORS — URL of the frontend (comma-separated for multiple)
WEB_ORIGIN=http://localhost:5173

# Storage: "local" for dev, "s3" for production
STORAGE_BACKEND=local
STORAGE_DIR=./storage

# Required when STORAGE_BACKEND=s3
S3_BUCKET=
S3_REGION=
S3_PUBLIC_URL_BASE=

PORT=3001
